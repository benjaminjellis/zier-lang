(use result)

;; Returns Ok if cond is True, Error with a message otherwise.
(pub let assert {cond} (if cond (Ok ()) (Error "assertion failed")))

;; Returns Ok if a equals b, Error with a formatted message otherwise.
(pub extern let assert_eq ~ ('a -> 'a -> (Result Unit String)) zier_testing_helpers/assert_eq)

;; Returns Ok if a does not equal b, Error with a formatted message otherwise.
(pub extern let assert_ne ~ ('a -> 'a -> (Result Unit String)) zier_testing_helpers/assert_ne)
